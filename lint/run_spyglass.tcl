################################################################################
# run_spyglass.tcl  —  SpyGlass Lint check for SM4 RTL
################################################################################

# ---- Create project ----------------------------------------------------------
new_project sm4_lint -force

# ---- Read all RTL source files -----------------------------------------------
read_file -type verilog [glob ../rtl/*.v]

# ---- Set top-level module ----------------------------------------------------
set_option top sm4_wrapper

# ---- Goal: RTL Lint ----------------------------------------------------------
set_option goal {lint_rtl}

# ---- Run ----------------------------------------------------------------------
current_goal lint_rtl
run_goal

# ---- Write reports ------------------------------------------------------------
write_report moresimple > ../lint/lint.log

# ---- Exit ----------------------------------------------------------------------
exit
